#include <dt-bindings/zmk/keys.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/kscan_mock.h>

/ {
    behaviors {
        sml: sticky_mod_layer {
            compatible = "zmk,behavior-sticky-mod-layer";
            #binding-cells = <2>;
            release-after-ms = <250>;
            quick-release;
            ignore-modifiers;
            ignored-key-positions = <0>;
            bindings = <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &mo 1         &kp A
                &kp C         &kp D
            >;
        };

        source_layer {
            bindings = <
                &trans        &sml LCTRL 2
                &sml RALT 3   &trans
            >;
        };

        lmod_layer {
            bindings = <
                &trans        &trans
                &trans        &sml LSHFT 2
            >;
        };

        rmod_layer {
            bindings = <
                &sml RCTRL 3  &trans
                &trans        &trans
            >;
        };
    };
};
